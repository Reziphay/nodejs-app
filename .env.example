NODE_ENV=development
HOST=0.0.0.0
PORT=3001
DOCKER_HOST_PORT=3001

# Local dev: connects to docker's exposed port
DATABASE_URL=postgresql://user:password@localhost:5433/dbname?schema=public

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=dbname
POSTGRES_PORT=5433

JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

STORAGE_DIR=storage
BASE_URL=http://localhost:3001
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
AUTH_EMAIL_VERIFICATION_TTL_MS=86400000
AUTH_PHONE_VERIFICATION_TTL_MS=600000
AUTH_PASSWORD_RESET_TTL_MS=3600000
AUTH_TWO_FACTOR_CHALLENGE_TTL_MS=600000
AUTH_TWO_FACTOR_ENROLL_TTL_MS=600000
AUTH_STEP_UP_TTL_MS=600000
AUTH_RESEND_INTERVAL_MS=60000
AUTH_MAX_CHALLENGE_DELIVERIES=5
AUTH_MAX_CHALLENGE_ATTEMPTS=5

# Comma-separated list of allowed CORS origins (no trailing slash, no spaces)
# Add your machine LAN IP if testing from other devices on the same Wi-Fi
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
